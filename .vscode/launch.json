{
	// Use IntelliSense to learn about possible attributes.
	// Hover to view descriptions of existing attributes.
	// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
	"version": "0.2.0",
	"configurations": [{
			"name": "debug Task-cli (LINUX) ",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/task-cli",
			"args": ["add", "banana"],
			"cwd": "${workspaceFolder}",
			"MIMode": "gdb",
			"miDebuggerPath": "/usr/bin/gdb",
			"preLaunchTask": "Make: Compile",
			"logging": {
				"moduleLoad": false,
				"trace": false,
				"engineLogging": false,
				"programOutput": true,
				"exceptions": true
			},
		}]
}
